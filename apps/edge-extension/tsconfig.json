{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM"],
    "types": ["chrome", "react", "react-dom", "@testing-library/jest-dom"],
    "paths": {
      "@pwbook/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@pwbook/shared-types/*": ["../../packages/shared-types/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
