    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vite-plugin-web-extension": "^4.0.0",
    "vitest": "^2.0.0"
  }
