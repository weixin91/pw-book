{
  "name": "edge-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && ../../node_modules/.pnpm/esbuild@0.27.7/node_modules/esbuild/bin/esbuild src/content/content-script.ts --bundle --outfile=dist/content.js --format=iife --target=chrome120 --minify",
