# ============================================================================
# pw-book .gitignore
# Covers Node.js / TypeScript, Kotlin / Android, OS, IDE, Secrets
# ============================================================================

# ----------------------------------------------------------------------------
# Secrets & Environment
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
keystore.properties
secrets.properties
google-services.json

# ----------------------------------------------------------------------------
# Node.js / TypeScript
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
out/
*.tsbuildinfo
*.map

# Coverage
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# Kotlin / Android / Gradle
# ----------------------------------------------------------------------------
.gradle/
build/
local.properties
*.iml
.idea/
*.hprof
.cxx/
*.apk
*.ap_
*.aab

# Android Studio captures
captures/
.externalNativeBuild

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3

# ----------------------------------------------------------------------------
# Logs & Temp
# ----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp

# ----------------------------------------------------------------------------
# OS
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
