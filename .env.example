# 自托管密码管理器环境配置

# 数据库（SQLite 单文件，自动创建）
DATABASE_URL="file:./data/pwbook.db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 注册邮箱白名单（可选，逗号分隔，不设置则允许所有邮箱）
ALLOWED_EMAILS=""

# 自动备份配置
BACKUP_ENABLED=false          # 是否启用自动备份
BACKUP_DIR="./backups"        # 备份文件存放目录
BACKUP_HOUR=3                 # 每天几点执行备份（0-23）
BACKUP_RETENTION_DAYS=7       # 备份保留天数

# 服务器配置
PORT=3000
NODE_ENV=production
